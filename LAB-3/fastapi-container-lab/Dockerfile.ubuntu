FROM ubuntu:24.04

RUN apt-get update && apt-get install -y python3 python3-venv python3-pip && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY main.py .

RUN python3 -m venv /app/venv
RUN /app/venv/bin/pip install --no-cache-dir fastapi uvicorn

CMD ["/app/venv/bin/uvicorn", "main:app", "--host", "0.0.0.0", "--port", "80"]
